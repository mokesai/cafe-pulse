# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
eslint-report.json
/data/purchase-orders/PO*
/data/*yaml
/data/*json

# next.js
/.next/
/out/

# production
/build

# python
/.venv/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local caches
.cache/
/tesseract-data/

# KDS images - ignore unused subdirectories, keep root-level images
/public/images/kds/photos/burritos/
/public/images/kds/photos/croissants/
/public/images/kds/photos/espressos/
/public/images/kds/photos/frappuccinos/
/public/images/kds/photos/muffins/
/public/images/kds/photos/pastries/
/public/images/kds/photos/refreshers/
/public/images/kds/photos/sandwiches/
.mcp.json

# Wanda workspace files (not for repo)
RENAME.md
.8x/

# Test credentials (never commit)
.env.test.local
tests/e2e/.auth/
